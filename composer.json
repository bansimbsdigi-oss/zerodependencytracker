{
    "name": "zerodependencytracker/app",
    "description": "Zero Dependency Tracker - Physiotherapy Progress Platform",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.5"
    },
    "autoload": {
        "psr-4": {
            "Config\\": "app/Config/",
            "App\\": "app/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/Support/"
        }
    },
    "scripts": {
    },
    "config": {
        "allow-plugins": {
            "codeigniter4/codeigniter4-standard": true
        }
    },
    "minimum-stability": "stable",
    "require-dev": {
        "kint-php/kint": "*"
    }
}
