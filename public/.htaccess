Options -Indexes

# ── Force HTTPS (uncomment ONLY after SSL certificate is active on Hostinger) ──
# <IfModule mod_rewrite.c>
#     RewriteCond %{HTTPS} off
#     RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>

# ── CI4 Front Controller Rewrite ─────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /zdt/

    # ── Legacy .php URL redirects (old plain-PHP app links) ──────────────────
    RewriteRule ^register\.php$          /zdt/register         [R=301,L]
    RewriteRule ^login\.php$             /zdt/login            [R=301,L]
    RewriteRule ^logout\.php$            /zdt/logout           [R=301,L]
    RewriteRule ^otp-verify\.php$        /zdt/otp-verify       [R=301,L]
    RewriteRule ^dashboard\.php$         /zdt/dashboard        [R=301,L]
    RewriteRule ^audit\.php$             /zdt/audit            [R=301,L]
    RewriteRule ^audit-report\.php$      /zdt/audit-report     [R=301,L]
    RewriteRule ^profile\.php$           /zdt/profile          [R=301,L]
    RewriteRule ^send_audit_reminders\.php$ /zdt/              [R=301,L]
    RewriteRule ^admin/login\.php$       /zdt/admin/login      [R=301,L]
    RewriteRule ^admin/logout\.php$      /zdt/admin/logout     [R=301,L]
    RewriteRule ^admin/dashboard\.php$   /zdt/admin/dashboard  [R=301,L]
    RewriteRule ^admin/clients/index\.php$  /zdt/admin/clients [R=301,L]
    RewriteRule ^admin/clients/create\.php$ /zdt/admin/clients/create [R=301,L]
    RewriteRule ^admin/audits/index\.php$   /zdt/admin/audits  [R=301,L]
    RewriteRule ^admin/audits/create\.php$  /zdt/admin/audits/create [R=301,L]
    RewriteRule ^admin/questions/index\.php$ /zdt/admin/questions [R=301,L]
    RewriteRule ^admin/notifications/index\.php$ /zdt/admin/notifications [R=301,L]

    # Allow direct access to real files and directories (assets, etc.)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Route everything else through CI4's index.php
    RewriteRule ^(.*)$ index.php/$1 [L,QSA]
</IfModule>

# ── Block direct access to sensitive file types ──────────────────────────────
<FilesMatch "\.(sql|log|sh|env|md|yml|yaml|lock|json|gitignore|dockerignore|htpasswd)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── PHP security settings ────────────────────────────────────────────────────
<IfModule mod_php.c>
    php_flag  display_errors          Off
    php_flag  log_errors              On
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
    php_value session.cookie_samesite Lax
    php_flag  session.cookie_secure   On
</IfModule>

<IfModule php8_module>
    php_flag  display_errors          Off
    php_flag  log_errors              On
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
    php_value session.cookie_samesite Lax
    php_flag  session.cookie_secure   On
</IfModule>

# ── Security headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options  "nosniff"
    Header always set X-Frame-Options          "SAMEORIGIN"
    Header always set X-XSS-Protection         "1; mode=block"
    Header always set Referrer-Policy          "strict-origin-when-cross-origin"
    Header always set Permissions-Policy       "geolocation=(), microphone=(), camera=()"
</IfModule>

# ── Static asset caching ─────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css              "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType image/png             "access plus 1 year"
    ExpiresByType image/jpeg            "access plus 1 year"
    ExpiresByType image/svg+xml         "access plus 1 year"
    ExpiresByType image/x-icon          "access plus 1 year"
    ExpiresByType font/woff2            "access plus 1 year"
</IfModule>

# ── Gzip compression ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/plain text/xml
</IfModule>
