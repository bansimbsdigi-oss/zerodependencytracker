Options -Indexes

# Block direct access to sensitive files
<FilesMatch "\.(env|sql|md|json|yml|yaml|lock|log|sh|gitignore|dockerignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Block access to config directory
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block config directory direct access
    RewriteRule ^config/config\.php$ - [F,L]
    RewriteRule ^\.env$ - [F,L]
    RewriteRule ^database/.*$ - [F,L]
    RewriteRule ^Dockerfile$ - [F,L]
    RewriteRule ^docker-compose.*$ - [F,L]
</IfModule>

# PHP settings for shared hosting
<IfModule mod_php.c>
    php_value session.cookie_httponly 1
    php_value session.use_strict_mode 1
    php_flag session.cookie_secure Off
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
