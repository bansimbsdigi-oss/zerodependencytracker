Options -Indexes

# ── Block all sensitive file types at root level ─────────────────────────────
<FilesMatch "\.(php|sql|log|sh|env|md|yml|yaml|lock|gitignore|dockerignore)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# ── Block direct access to sensitive directories ─────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block WordPress scanner paths
    RewriteRule ^wp-login\.php$  - [F,L]
    RewriteRule ^wp-admin/.*$    - [F,L]

    # Block sensitive directories — deny direct access
    RewriteRule ^app/.*$      - [F,L]
    RewriteRule ^vendor/.*$   - [F,L]
    RewriteRule ^writable/.*$ - [F,L]
    RewriteRule ^database/.*$ - [F,L]
    RewriteRule ^\.env$       - [F,L]
    RewriteRule ^env$         - [F,L]
    RewriteRule ^composer.*$  - [F,L]
    RewriteRule ^Dockerfile$  - [F,L]
    RewriteRule ^spark$       - [F,L]

    # ── Route all web requests into public/ ──────────────────────────────────
    # ONLY needed when Hostinger document root = project root (not recommended).
    # If document root is set to public/ in Hostinger hPanel, DELETE rules below.
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>

# ── Security headers ─────────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options         "SAMEORIGIN"
    Header always set Referrer-Policy         "strict-origin-when-cross-origin"
</IfModule>
